# Ollama Configuration
OLLAMA_HOST=http://127.0.0.1:11434
# Models: qwen3:1.7b or deepseek-r1:1.5b
OLLAMA_MODEL=qwen3:1.7b

# Video Configuration
VIDEO_SOURCE=fog_video.mp4
# Set to 0 for webcam if video file not available
USE_WEBCAM=false

# GPS Configuration
USE_MOCK_GPS=false
MOCK_LAT=28.6139
MOCK_LON=77.2090

# Alert Configuration
VOICE_ALERT_ENABLED=true
ALERT_COOLDOWN_SECONDS=10

# Object Detection
CONFIDENCE_THRESHOLD=0.5
DETECTION_DEVICE=0  # 0 for GPU, cpu for CPU

# Road Context
NOMINATIM_USER_AGENT=road-awareness-system

# Fog Detection
FOG_DENSITY_THRESHOLD_CRITICAL=80
FOG_DENSITY_THRESHOLD_HIGH=60
FOG_DENSITY_THRESHOLD_MEDIUM=40

# LLM Inference
LLM_INFERENCE_INTERVAL=5  # seconds
GPS_UPDATE_INTERVAL=10    # seconds
VIDEO_ANALYSIS_INTERVAL=2 # seconds
